# Anthropic API key — used ONLY by the `npm run enrich` script and the
# optional /api/ask route. Set the real value in Vercel project settings
# (Environment Variables) and in a local, untracked .env.local for enrich.
# NEVER commit the real key.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model used for bulk enrichment.
# Defaults to claude-sonnet-4-6.
# ENRICH_MODEL=claude-opus-4-8
